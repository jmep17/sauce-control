{
  "name": "sauce-control",
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "description": "Record real network traffic from an Auth0-backed repo, then relaunch it fully offline against a self-issuing mock proxy.",
  "type": "module",
  "bin": {
    "sauce-control": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/cli.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@octokit/rest": "^21.0.2",
    "commander": "^12.1.0",
    "jose": "^5.9.6",
    "picocolors": "^1.1.1",
    "selfsigned": "^2.4.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "playwright": "^1.49.0",
    "prettier": "^3.9.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "peerDependencies": {
    "playwright": "^1.49.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
